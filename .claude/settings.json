{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "sh \"$CLAUDE_PROJECT_DIR/.claude/hooks/commit-guard.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "sh \"$CLAUDE_PROJECT_DIR/.claude/hooks/bump-last-modified.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "sh \"$CLAUDE_PROJECT_DIR/.claude/hooks/readme-sync-prompt.sh\""
          }
        ]
      }
    ]
  }
}
