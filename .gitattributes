# Normalise line endings and declare binary types.
# LF for all text so the repo is consistent across Windows / macOS / Linux.

* text=auto eol=lf

*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf
*.py    text eol=lf
*.ps1   text eol=lf

# Binary assets — never line-ending-converted, never diffed as text.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.bmp   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.mp4   binary
*.webm  binary
